generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // eslint-disable-next-line @typescript-eslint/tslint/config
  url      = env("DATABASE_URL")
}

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  workflowDefinitions WorkflowDefinition[]

  @@map("tenants")
}

model Role {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(50)  // ADMIN, EDITOR, VIEWER
  users     User[]

  @@map("roles")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(255)
  password     String    @db.VarChar(255)
  name         String    @db.VarChar(255)
  roleId       Int
  tenantId     Int
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  role         Role      @relation(fields: [roleId], references: [id])
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdWorkflows  WorkflowDefinition[] @relation("WorkflowCreator")
  stepRuns     StepRun[]

  @@map("users")
}

model WorkflowDefinition {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(255)
  description    String?   @db.Text
  tenantId       Int
  createdById    Int
  status         WorkflowStatus @default(ACTIVE)
  cronExpression String?   @db.VarChar(100)
  webhookToken   String?   @unique @db.VarChar(64)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy      User      @relation("WorkflowCreator", fields: [createdById], references: [id])
  versions       WorkflowVersion[]
  runs           WorkflowRun[]

  @@map("workflow_definitions")
}

enum WorkflowStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

model WorkflowVersion {
  id                  Int       @id @default(autoincrement())
  workflowDefinitionId Int
  version             Int
  definition          Json      // DAG definition
  createdAt           DateTime  @default(now())

  workflowDefinition  WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)

  @@unique([workflowDefinitionId, version])
  @@map("workflow_versions")
}

model WorkflowRun {
  id                  Int       @id @default(autoincrement())
  workflowDefinitionId Int
  workflowVersionId   Int
  status              RunStatus @default(PENDING)
  idempotencyKey     String?   @db.VarChar(255)  // For webhook idempotency
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())

  workflowDefinition  WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id])
  stepRuns            StepRun[]

  @@unique([workflowDefinitionId, idempotencyKey])
  @@map("workflow_runs")
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  TIMED_OUT
  CANCELLED
}

model StepRun {
  id           Int       @id @default(autoincrement())
  workflowRunId Int
  stepId       String    @db.VarChar(100)
  stepName     String    @db.VarChar(255)
  stepType     StepType
  status       StepStatus @default(PENDING)
  retryCount   Int       @default(0)
  maxRetries   Int       @default(3)
  output       Json?
  error        String?   @db.Text
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  workflowRun  WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id])
  userId       Int?
  logs         StepLog[]

  @@index([workflowRunId])
  @@index([stepId])
  @@index([status, createdAt])
  @@map("step_runs")
}

// High-volume execution log storage using append-only log pattern
// This table stores detailed execution events for audit and debugging
model StepLog {
  id           Int       @id @default(autoincrement())
  stepRunId    Int
  level        LogLevel  @default(INFO)
  message      String    @db.Text
  metadata     Json?     // Additional context (request/response data, timing info, etc.)
  createdAt    DateTime  @default(now())

  stepRun      StepRun   @relation(fields: [stepRunId], references: [id], onDelete: Cascade)

  // Indexes for common query patterns
  @@index([stepRunId, createdAt])  // Get logs for a step run in order
  @@index([level, createdAt])      // Filter by log level over time
  @@index([createdAt])             // Time-series queries for retention policies

  @@map("step_logs")
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum StepType {
  START
  END
  HTTP_CALL
  SCRIPT
  DELAY
  CONDITIONAL
}

enum StepStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}
